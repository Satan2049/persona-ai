# Contact numbers shared in the psychologist prompt and high-risk escalation replies
SOCIAL_EMERGENCY_NUMBER=123
RESEARCHER_NUMBER=09373759943

# OpenAI-compatible chat API (Ollama, vLLM, cloud gateway, etc.)
MODEL_API_BASE=http://127.0.0.1:11434/v1
MODEL_API_KEY=api-key
MODEL_NAME=your-chat-model
MODEL_TIMEOUT_SECONDS=25
MODEL_MAX_RETRIES=3
MODEL_TEMPERATURE=0.5
# Max completion tokens (shorter replies). Set to 0 to omit max_tokens for the API.
# If the model hits this cap, the backend trims to the last full sentence and may retry once with a shorter reply.
MODEL_MAX_TOKENS=380

# Piper TTS — not in repo. Binary: https://github.com/OHF-Voice/piper1-gpl
# Voices: https://huggingface.co/rhasspy/piper-voices — see ../README.md#piper-tts-setup
# Windows: full path to piper.exe recommended
PIPER_BIN=piper

# Folder for downloaded Piper voices (*.onnx + matching *.onnx.json); created empty in git
PIPER_MODELS_DIR=../piper_models

# Optional: single extra model path (also listed if file exists)
# PIPER_MODEL_PATH=/path/to/voice.onnx

# Optional default voice id (must match locale in UI); first matching voice is used if unset
PIPER_VOICE_ID_FA=
PIPER_VOICE_ID_EN=

PIPER_SPEAKER_ID=
# If a voice fails with ONNX "Missing Input: sid", try PIPER_SPEAKER_ID=0 or PIPER_ALWAYS_SPEAKER=1
PIPER_ALWAYS_SPEAKER=
PIPER_TIMEOUT_SECONDS=30
# PIPER_DEBUG=1

AUDIO_OUTPUT_DIR=../audio

# RAG (FAQ-grounded retrieval) — enabled by default; index builds on backend startup
RAG_ENABLED=true
RAG_BUILD_ON_STARTUP=true
RAG_FAQ_PATH=../data/faq_dataset.json
RAG_INDEX_DIR=../data/rag_index
# Local Ollama: defaults to MODEL_API_BASE / MODEL_API_KEY if unset
EMBEDDING_API_BASE=http://127.0.0.1:11434/v1
EMBEDDING_API_KEY=local-key
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_TIMEOUT_SECONDS=30
RAG_TOP_K=4
RAG_MIN_SCORE=0.35
